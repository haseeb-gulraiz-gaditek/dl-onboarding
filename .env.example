# Mesh -- example environment configuration.
# Copy to .env and fill in values. Never commit .env.

# MongoDB connection URI.
#   Easiest path: free MongoDB Atlas cluster
#     -> https://www.mongodb.com/cloud/atlas/register
#     -> use the connection string Atlas gives you (mongodb+srv://...).
#   Local mongod install:    mongodb://localhost:27017
#   Optional docker stack:   mongodb://localhost:27017
MONGODB_URI=

# Logical database name inside the cluster.
MONGODB_DB=mesh

# JWT signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# JWT expiry in days.
JWT_EXPIRY_DAYS=7

# Admin email allowlist (comma-separated, case-insensitive). Used by
# /admin/* endpoints. Solo V1: just your own email. V1.5+ replaces
# this with proper RBAC.
ADMIN_EMAILS=

# OpenAI API key for text-embedding-3-small embeddings.
# Get one at: https://platform.openai.com/api-keys
# V1 cost: < $1 to embed the entire 547-tool catalog plus a few
# hundred profile re-embeds.
OPENAI_API_KEY=

# Weaviate Cloud Services (free 14-day sandbox).
# Sign up at: https://console.weaviate.cloud
# Create a Sandbox cluster, then copy the REST endpoint URL and
# the Admin API key from the cluster's "API Keys" tab.
WEAVIATE_URL=
WEAVIATE_API_KEY=
